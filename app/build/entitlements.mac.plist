<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron/V8 JIT under hardened runtime -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- V8 executable memory (Electron guidance for hardened runtime) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- The bundled sox/ffmpeg dylibs and Python extension modules are loaded by our re-signed binaries -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- The Live tab captures microphone audio; hardened runtime blocks mic access without this even with NSMicrophoneUsageDescription present -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
