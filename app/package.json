{
  "name": "sound-buddy-app",
  "version": "0.8.2",
  "license": "SEE LICENSE IN LICENSE",
  "description": "Sound Buddy — desktop audio analysis and grading for Apple Silicon Macs.",
  "author": "on-par",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "npm run build --prefix renderer && tsc",
    "lint": "tsc --noEmit && npm run lint --prefix renderer",
    "start": "npm run build && electron dist/electron/main.js",
    "dev": "node scripts/dev.mjs",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --passWithNoTests --coverage",
    "test:e2e": "npx playwright test --config=playwright.config.ts",
    "test:e2e:stubbed": "SB_E2E_STUBBED_ONLY=1 npx playwright test --config=playwright.config.ts",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "playwright": "^1.61.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
