<section class="browser-tool card" data-browser-analyzer>
  <div class="browser-shell">
    <aside class="browser-sidebar">
      <div class="browser-sidebar-head">
        <span class="eyebrow">Browser Lite</span>
        <h2>Run a fast local stereo check.</h2>
        <p>
          Upload a stereo recording or tap a live input. Everything stays in the browser. No upload,
          no account, no “send your service to our servers” story.
        </p>
      </div>

      <div class="control-group">
        <label for="preset-select">Target preset</label>
        <select id="preset-select" class="browser-select">
          <option value="worship">Worship service</option>
          <option value="speech">Speech-forward stream</option>
          <option value="broadcast">Tighter broadcast handoff</option>
        </select>
      </div>

      <div class="control-group">
        <label for="audio-file">Analyze a stereo file</label>
        <label class="dropzone" for="audio-file">
          <input id="audio-file" type="file" accept="audio/*" />
          <span class="dropzone-title">Drop a stereo WAV, AIFF, MP3, AAC, or M4A here</span>
          <span class="dropzone-copy">Sound Buddy Browser Lite decodes it locally and gives you a quick mix read.</span>
        </label>
      </div>

      <div class="control-group">
        <div class="control-label-row">
          <label for="device-select">Live stereo input</label>
          <button type="button" class="mini-btn" data-refresh-devices>Refresh</button>
        </div>
        <select id="device-select" class="browser-select">
          <option value="">Default input</option>
        </select>
        <div class="live-actions">
          <button type="button" class="btn btn-primary" data-start-live>Start live check</button>
          <button type="button" class="btn btn-ghost" data-stop-live disabled>Stop</button>
        </div>
        <p class="hint">Single stereo input only. Best for a stream feed, matrix out, or quick laptop capture.</p>
      </div>

      <div class="control-group">
        <div class="control-label-row">
          <label>Quick-export summary</label>
          <button type="button" class="mini-btn" data-copy-summary disabled>Copy notes</button>
        </div>
        <p class="hint" data-copy-status>Once you run a check, you can copy a ready-to-send summary for your team.</p>
      </div>
    </aside>

    <div class="browser-main">
      <div class="status-bar">
        <div class="status-pill" data-run-mode>Idle</div>
        <div class="status-copy" data-status-copy>Choose a stereo file or start a live check.</div>
      </div>

      <article class="live-meter-card card" data-live-meter>
        <div class="live-meter-head">
          <span class="meter-label">Live level</span>
          <div class="live-meter-controls">
            <select id="weighting-select" class="browser-select browser-select-compact">
              <option value="A" selected>A-weighted</option>
              <option value="C">C-weighted</option>
              <option value="Z">Z (unweighted)</option>
            </select>
            <select id="response-select" class="browser-select browser-select-compact">
              <option value="slow" selected>Slow — 1 s</option>
              <option value="fast">Fast — 125 ms</option>
            </select>
          </div>
        </div>

        <strong class="live-meter-value mono" data-live-level>-- dBFS</strong>
        <span class="live-meter-mode" data-live-level-mode>A-weighted · slow · dBFS</span>

        <div class="live-meter-gauge">
          <div class="live-meter-rail">
            <span class="live-meter-target-band" data-live-target-band></span>
            <span class="live-meter-level-bar" data-live-level-bar></span>
          </div>
          <div class="live-meter-ticks">
            <span>-60 dBFS</span>
            <span>0 dBFS</span>
          </div>
        </div>

        <div class="live-meter-status" data-live-range-status>Start a live check to meter your room feed.</div>

        <p class="live-meter-note">
          Reads dBFS — level relative to this input's digital full scale, smoothed like a slow SPL
          meter. Browser inputs aren't calibrated, so this is not true SPL; use it as a relative
          loudness window, not a legal-limit meter.
        </p>
      </article>

      <div class="hero-meters">
        <article class="meter-card card">
          <span class="meter-label">Quick grade</span>
          <div class="grade-stack">
            <strong class="grade-letter" data-grade-letter>--</strong>
            <span class="grade-score mono" data-grade-score>0 / 100</span>
          </div>
          <p class="meter-note" data-grade-note>Browser Lite waits for a real signal before it judges anything.</p>
        </article>

        <article class="meter-card card">
          <span class="meter-label">Peak</span>
          <strong class="meter-value mono" data-peak>-- dBFS</strong>
          <div class="meter-rail"><span data-peak-bar></span></div>
          <p class="meter-note">Stay below -1 dBFS for a comfortable handoff.</p>
        </article>

        <article class="meter-card card">
          <span class="meter-label">Body</span>
          <strong class="meter-value mono" data-rms>-- dBFS</strong>
          <div class="meter-rail"><span data-rms-bar></span></div>
          <p class="meter-note">A rough loudness read for the current preset.</p>
        </article>

        <article class="meter-card card">
          <span class="meter-label">Stereo health</span>
          <strong class="meter-value mono" data-correlation>--</strong>
          <div class="meter-rail"><span data-correlation-bar></span></div>
          <p class="meter-note">Correlation catches width and phase trouble fast.</p>
        </article>
      </div>

      <div class="browser-grid">
        <article class="insight-card card">
          <div class="insight-head">
            <span class="eyebrow">Mix read</span>
            <h3>What the browser sees</h3>
          </div>
          <ul class="insight-list" data-summary-list>
            <li>Upload a file or start a live check to generate notes.</li>
          </ul>
        </article>

        <article class="spectrum-card card">
          <div class="insight-head">
            <span class="eyebrow">Band balance</span>
            <h3>Seven bands, evenly spaced</h3>
          </div>
          <p class="band-plot-note">
            Live reads are a 3-second rolling average, not an instant frame; file reads average the
            whole take.
          </p>
          <span class="band-avg-note" data-band-avg-note>Waiting for audio</span>
          <div class="eq-plot" data-band-bars></div>
          <div class="eq-labels" data-band-labels></div>
        </article>
      </div>

      <div class="detail-grid">
        <article class="detail-card card">
          <span class="eyebrow">Session details</span>
          <dl class="detail-list">
            <div><dt>Source</dt><dd data-source>None yet</dd></div>
            <div><dt>Duration</dt><dd data-duration>--</dd></div>
            <div><dt>Sample rate</dt><dd data-sample-rate>--</dd></div>
            <div><dt>Balance</dt><dd data-balance>--</dd></div>
            <div><dt>Dynamic spread</dt><dd data-dynamic>--</dd></div>
            <div><dt>Centroid</dt><dd data-centroid>--</dd></div>
          </dl>
        </article>

        <article class="detail-card card">
          <span class="eyebrow">Worth using because</span>
          <ul class="value-list">
            <li>It catches “too hot,” “too muddy,” and “speech got lost” problems before rehearsal is over.</li>
            <li>Live mode gives you a fast sanity check on a single stereo feed without installing anything.</li>
            <li>Copy notes turns the result into something you can paste in Slack, Planning Center, or a text thread.</li>
          </ul>
        </article>
      </div>
    </div>
  </div>
</section>

<script>
  // Converted from the recovered WIP's `<script is:inline>` to a processed,
  // externally-emitted module script (astro.config.mjs sets
  // vite.build.assetsInlineLimit: 0) so the strict `script-src 'self'` CSP in
  // site/public/_headers isn't violated. Behavior is unchanged from the WIP —
  // only types/guards were added to satisfy `astro check` under strict TS.
  import {
    createLevelSmoother,
    evaluateRange,
    meterPercent,
    weightingCorrectionDb,
    isWeighting,
    isMeterResponse,
    SLOW_TIME_CONSTANT_MS,
    FAST_TIME_CONSTANT_MS,
    LIVE_METER_MIN_DB,
    LIVE_METER_MAX_DB,
    type Weighting,
    type MeterResponse,
    type TargetRange,
  } from '../lib/spl-meter';
  import {
    EQ_BAND_DEFS,
    EQ_GRID_DB,
    LIVE_AVG_WINDOW_MS,
    eqBarColumns,
    eqBarPercent,
    bandView,
    loudestBandIndex,
    barReadoutBottomPct,
    createRollingAverager,
    createRollingMax,
    type BandKey,
  } from '../lib/eq-bands';

  (() => {
    const root = document.querySelector<HTMLElement>('[data-browser-analyzer]');
    if (!root) return;

    type PresetKey = 'worship' | 'speech' | 'broadcast';

    interface PresetConfig {
      label: string;
      rmsTarget: number;
      peakTarget: number;
      dynamicTarget: number;
      centroidTarget: number;
      clarityTarget: number;
      // Music-playback window (dBFS, A-weighted slow) for the live decibel
      // meter — the hook future per-user profiles can supply their own
      // TargetRange through, without touching the meter itself.
      liveTarget: TargetRange;
    }

    const PRESETS: Record<PresetKey, PresetConfig> = {
      worship: {
        label: 'Worship service',
        rmsTarget: -18,
        peakTarget: -1,
        dynamicTarget: 10,
        centroidTarget: 2200,
        clarityTarget: 0.9,
        liveTarget: { minDb: -22, maxDb: -8 },
      },
      speech: {
        label: 'Speech-forward stream',
        rmsTarget: -16,
        peakTarget: -1,
        dynamicTarget: 8,
        centroidTarget: 2600,
        clarityTarget: 1.2,
        liveTarget: { minDb: -26, maxDb: -12 },
      },
      broadcast: {
        label: 'Tighter broadcast handoff',
        rmsTarget: -14,
        peakTarget: -1,
        dynamicTarget: 7,
        centroidTarget: 2400,
        clarityTarget: 1.05,
        liveTarget: { minDb: -18, maxDb: -8 },
      },
    };

    function isPresetKey(value: string): value is PresetKey {
      return value === 'worship' || value === 'speech' || value === 'broadcast';
    }

    interface AnalysisResult {
      source: string;
      duration: number;
      sampleRate: number;
      peakDb: number;
      rmsDb: number;
      correlation: number;
      balanceDb: number;
      dynamicRange: number;
      centroid: number;
      bands: Record<BandKey, number>;
    }

    interface GradeResult {
      score: number;
      letter: string;
    }

    /** Every selector below targets markup declared in this component's own template. */
    function required<T extends Element>(el: T | null, selector: string): T {
      if (!el) throw new Error(`Browser Lite analyzer markup is missing "${selector}".`);
      return el;
    }

    const els = {
      preset: required(root.querySelector<HTMLSelectElement>('#preset-select'), '#preset-select'),
      file: required(root.querySelector<HTMLInputElement>('#audio-file'), '#audio-file'),
      device: required(root.querySelector<HTMLSelectElement>('#device-select'), '#device-select'),
      startLive: required(root.querySelector<HTMLButtonElement>('[data-start-live]'), '[data-start-live]'),
      stopLive: required(root.querySelector<HTMLButtonElement>('[data-stop-live]'), '[data-stop-live]'),
      refreshDevices: required(root.querySelector<HTMLButtonElement>('[data-refresh-devices]'), '[data-refresh-devices]'),
      copySummary: required(root.querySelector<HTMLButtonElement>('[data-copy-summary]'), '[data-copy-summary]'),
      copyStatus: required(root.querySelector<HTMLElement>('[data-copy-status]'), '[data-copy-status]'),
      runMode: required(root.querySelector<HTMLElement>('[data-run-mode]'), '[data-run-mode]'),
      statusCopy: required(root.querySelector<HTMLElement>('[data-status-copy]'), '[data-status-copy]'),
      weighting: required(root.querySelector<HTMLSelectElement>('#weighting-select'), '#weighting-select'),
      response: required(root.querySelector<HTMLSelectElement>('#response-select'), '#response-select'),
      liveLevel: required(root.querySelector<HTMLElement>('[data-live-level]'), '[data-live-level]'),
      liveLevelMode: required(root.querySelector<HTMLElement>('[data-live-level-mode]'), '[data-live-level-mode]'),
      liveLevelBar: required(root.querySelector<HTMLElement>('[data-live-level-bar]'), '[data-live-level-bar]'),
      liveTargetBand: required(root.querySelector<HTMLElement>('[data-live-target-band]'), '[data-live-target-band]'),
      liveRangeStatus: required(root.querySelector<HTMLElement>('[data-live-range-status]'), '[data-live-range-status]'),
      gradeLetter: required(root.querySelector<HTMLElement>('[data-grade-letter]'), '[data-grade-letter]'),
      gradeScore: required(root.querySelector<HTMLElement>('[data-grade-score]'), '[data-grade-score]'),
      gradeNote: required(root.querySelector<HTMLElement>('[data-grade-note]'), '[data-grade-note]'),
      peak: required(root.querySelector<HTMLElement>('[data-peak]'), '[data-peak]'),
      peakBar: required(root.querySelector<HTMLElement>('[data-peak-bar]'), '[data-peak-bar]'),
      rms: required(root.querySelector<HTMLElement>('[data-rms]'), '[data-rms]'),
      rmsBar: required(root.querySelector<HTMLElement>('[data-rms-bar]'), '[data-rms-bar]'),
      correlation: required(root.querySelector<HTMLElement>('[data-correlation]'), '[data-correlation]'),
      correlationBar: required(root.querySelector<HTMLElement>('[data-correlation-bar]'), '[data-correlation-bar]'),
      summaryList: required(root.querySelector<HTMLElement>('[data-summary-list]'), '[data-summary-list]'),
      bandBars: required(root.querySelector<HTMLElement>('[data-band-bars]'), '[data-band-bars]'),
      bandLabels: required(root.querySelector<HTMLElement>('[data-band-labels]'), '[data-band-labels]'),
      bandAvgNote: required(root.querySelector<HTMLElement>('[data-band-avg-note]'), '[data-band-avg-note]'),
      source: required(root.querySelector<HTMLElement>('[data-source]'), '[data-source]'),
      duration: required(root.querySelector<HTMLElement>('[data-duration]'), '[data-duration]'),
      sampleRate: required(root.querySelector<HTMLElement>('[data-sample-rate]'), '[data-sample-rate]'),
      balance: required(root.querySelector<HTMLElement>('[data-balance]'), '[data-balance]'),
      dynamic: required(root.querySelector<HTMLElement>('[data-dynamic]'), '[data-dynamic]'),
      centroid: required(root.querySelector<HTMLElement>('[data-centroid]'), '[data-centroid]'),
    };

    const state: {
      audioContext: AudioContext | null;
      stream: MediaStream | null;
      animationFrame: number;
      summaryText: string;
      lastResult: AnalysisResult | null;
      weighting: Weighting;
      response: MeterResponse;
      levelSmoother: ReturnType<typeof createLevelSmoother>;
      lastTickMs: number | null;
      liveLevelDb: number | null;
      bandAverager: ReturnType<typeof createRollingAverager>;
      scalarAverager: ReturnType<typeof createRollingAverager>;
      rmsAverager: ReturnType<typeof createRollingAverager>;
      peakHold: ReturnType<typeof createRollingMax>;
    } = {
      audioContext: null,
      stream: null,
      animationFrame: 0,
      summaryText: '',
      lastResult: null,
      weighting: 'A',
      response: 'slow',
      levelSmoother: createLevelSmoother(SLOW_TIME_CONSTANT_MS),
      lastTickMs: null,
      liveLevelDb: null,
      bandAverager: createRollingAverager(LIVE_AVG_WINDOW_MS, 'db'),
      scalarAverager: createRollingAverager(LIVE_AVG_WINDOW_MS, 'linear'),
      rmsAverager: createRollingAverager(LIVE_AVG_WINDOW_MS, 'db'),
      peakHold: createRollingMax(LIVE_AVG_WINDOW_MS),
    };

    const RESPONSE_TIME_CONSTANTS_MS: Record<MeterResponse, number> = {
      slow: SLOW_TIME_CONSTANT_MS,
      fast: FAST_TIME_CONSTANT_MS,
    };

    const WEIGHTING_LABELS: Record<Weighting, string> = {
      A: 'A-weighted',
      C: 'C-weighted',
      Z: 'Z (unweighted)',
    };

    function activeLiveTarget(): TargetRange {
      const presetKey = els.preset.value;
      const preset = isPresetKey(presetKey) ? PRESETS[presetKey] : PRESETS.worship;
      return preset.liveTarget;
    }

    function renderLiveTargetBand(): void {
      const target = activeLiveTarget();
      const left = meterPercent(target.minDb, LIVE_METER_MIN_DB, LIVE_METER_MAX_DB);
      const right = meterPercent(target.maxDb, LIVE_METER_MIN_DB, LIVE_METER_MAX_DB);
      els.liveTargetBand.style.left = `${left}%`;
      els.liveTargetBand.style.width = `${Math.max(0, right - left)}%`;
    }

    function renderLiveLevelMode(): void {
      els.liveLevelMode.textContent =
        `${WEIGHTING_LABELS[state.weighting]} · ${state.response} · dBFS`;
    }

    function renderLiveLevel(displayDb: number | null): void {
      state.liveLevelDb = displayDb;
      if (displayDb === null) {
        els.liveLevel.textContent = '-- dBFS';
        els.liveLevelBar.style.width = '0%';
        els.liveRangeStatus.textContent = 'Start a live check to meter your room feed.';
        els.liveRangeStatus.dataset.status = '';
        return;
      }

      els.liveLevel.textContent = formatDb(displayDb);
      els.liveLevelBar.style.width = `${meterPercent(displayDb, LIVE_METER_MIN_DB, LIVE_METER_MAX_DB)}%`;

      const status = evaluateRange(displayDb, activeLiveTarget());
      els.liveRangeStatus.dataset.status = status;
      els.liveRangeStatus.textContent =
        status === 'below' ? 'Below target' : status === 'above' ? 'Above target' : 'In the target window';
    }

    function db(value: number): number {
      return 20 * Math.log10(Math.max(value, 1e-7));
    }

    function formatDb(value: number): string {
      if (!Number.isFinite(value)) return '-- dBFS';
      return `${value.toFixed(1)} dBFS`;
    }

    function formatHz(value: number): string {
      if (!Number.isFinite(value)) return '--';
      return value >= 1000 ? `${(value / 1000).toFixed(1)} kHz` : `${Math.round(value)} Hz`;
    }

    function formatSeconds(value: number): string {
      if (!Number.isFinite(value)) return '--';
      // Round the total first, then split — rounding mins/secs separately can
      // carry secs to 60 (e.g. 59.6s -> "0:60" instead of "1:00").
      const total = Math.round(value);
      const mins = Math.floor(total / 60);
      const secs = total % 60;
      return `${mins}:${String(secs).padStart(2, '0')}`;
    }

    function clamp(value: number, min: number, max: number): number {
      return Math.min(max, Math.max(min, value));
    }

    function percentile(values: number[], p: number): number {
      if (!values.length) return 0;
      const sorted = [...values].sort((a, b) => a - b);
      const idx = clamp(Math.round((sorted.length - 1) * p), 0, sorted.length - 1);
      return sorted[idx];
    }

    function downmix(left: Float32Array, right: Float32Array | null): Float32Array {
      const mono = new Float32Array(left.length);
      for (let i = 0; i < left.length; i += 1) {
        mono[i] = right ? (left[i] + right[i]) * 0.5 : left[i];
      }
      return mono;
    }

    function computeRms(data: Float32Array): number {
      let sum = 0;
      for (let i = 0; i < data.length; i += 1) sum += data[i] * data[i];
      return Math.sqrt(sum / Math.max(1, data.length));
    }

    function computePeak(left: Float32Array, right: Float32Array | null): number {
      let peak = 0;
      for (let i = 0; i < left.length; i += 1) {
        peak = Math.max(peak, Math.abs(left[i]), right ? Math.abs(right[i]) : 0);
      }
      return peak;
    }

    function computeCorrelation(left: Float32Array, right: Float32Array | null): number {
      if (!right) return 1;
      let sumL = 0;
      let sumR = 0;
      let sumLL = 0;
      let sumRR = 0;
      let sumLR = 0;
      for (let i = 0; i < left.length; i += 1) {
        const l = left[i];
        const r = right[i];
        sumL += l;
        sumR += r;
        sumLL += l * l;
        sumRR += r * r;
        sumLR += l * r;
      }
      const n = left.length || 1;
      const cov = sumLR / n - (sumL / n) * (sumR / n);
      const varL = sumLL / n - (sumL / n) * (sumL / n);
      const varR = sumRR / n - (sumR / n) * (sumR / n);
      if (varL <= 0 || varR <= 0) return 1;
      return clamp(cov / Math.sqrt(varL * varR), -1, 1);
    }

    const SILENCE_FLOOR_DB = -90;

    /** A near-silent right channel means a mono source (e.g. laptop mic through
     * a 2-channel splitter) rather than a real L/R imbalance — report 0 dB
     * instead of leftDb minus the noise floor. */
    function computeBalanceDb(left: Float32Array, right: Float32Array | null): number {
      if (!right) return 0;
      const leftDb = db(computeRms(left));
      const rightDb = db(computeRms(right));
      if (rightDb <= SILENCE_FLOOR_DB) return 0;
      return leftDb - rightDb;
    }

    function computeWindowedDynamic(mono: Float32Array, sampleRate: number): number {
      const frameSize = Math.max(512, Math.floor(sampleRate * 0.35));
      const frames: number[] = [];
      for (let start = 0; start + frameSize <= mono.length; start += frameSize) {
        let sum = 0;
        for (let i = start; i < start + frameSize; i += 1) sum += mono[i] * mono[i];
        frames.push(db(Math.sqrt(sum / frameSize)));
      }
      if (!frames.length) return 0;
      return percentile(frames, 0.9) - percentile(frames, 0.1);
    }

    async function measureBandDb(mono: Float32Array, sampleRate: number, low: number, high: number): Promise<number> {
      const ctx = new OfflineAudioContext(1, mono.length, sampleRate);
      const buffer = ctx.createBuffer(1, mono.length, sampleRate);
      // `mono` is a plain Float32Array (ArrayBufferLike-backed) but lib.dom's
      // copyToChannel narrowed its param to Float32Array<ArrayBuffer> in TS 5.7+;
      // the buffer is always a real ArrayBuffer at runtime, so this cast is safe.
      buffer.copyToChannel(mono as Float32Array<ArrayBuffer>, 0);
      const source = ctx.createBufferSource();
      source.buffer = buffer;

      let node: AudioNode = source;
      if (low) {
        const hp = ctx.createBiquadFilter();
        hp.type = 'highpass';
        hp.frequency.value = low;
        node.connect(hp);
        node = hp;
      }
      if (high) {
        const lp = ctx.createBiquadFilter();
        lp.type = 'lowpass';
        lp.frequency.value = high;
        node.connect(lp);
        node = lp;
      }
      node.connect(ctx.destination);
      source.start();
      const rendered = await ctx.startRendering();
      return db(computeRms(rendered.getChannelData(0)));
    }

    async function analyzeDecodedBuffer(buffer: AudioBuffer, sourceLabel: string): Promise<void> {
      const left = buffer.getChannelData(0);
      const right = buffer.numberOfChannels > 1 ? buffer.getChannelData(1) : null;
      const mono = downmix(left, right);
      const rmsDb = db(computeRms(mono));
      const peakDb = db(computePeak(left, right));
      const correlation = computeCorrelation(left, right);
      const balanceDb = computeBalanceDb(left, right);
      const dynamicRange = computeWindowedDynamic(mono, buffer.sampleRate);
      // Each band's OfflineAudioContext render is independent of the others,
      // so run them concurrently rather than serializing 7 renders — this is
      // the difference between a "quick check" and a multi-second wait on a
      // longer service recording.
      const bandEntries = await Promise.all(
        EQ_BAND_DEFS.map(async (band) => [band.key, await measureBandDb(mono, buffer.sampleRate, band.lo, band.hi)] as const),
      );
      const bandValues = Object.fromEntries(bandEntries) as Record<BandKey, number>;
      const centroid = centroidFromBandDbs(EQ_BAND_DEFS.map((band) => bandValues[band.key]));

      const result: AnalysisResult = {
        source: sourceLabel,
        duration: buffer.duration,
        sampleRate: buffer.sampleRate,
        peakDb,
        rmsDb,
        correlation,
        balanceDb,
        dynamicRange,
        centroid,
        bands: bandValues,
      };

      setBandAvgNote('Whole-file average');
      applyResult(result);
    }

    /** Linear-weighted spectral centroid from per-band dB levels, in EQ_BAND_DEFS order. */
    function centroidFromBandDbs(bandDbs: number[]): number {
      let numerator = 0;
      let denominator = 0;
      EQ_BAND_DEFS.forEach((band, i) => {
        const linear = Math.pow(10, (bandDbs[i] ?? -120) / 20);
        numerator += linear * band.center;
        denominator += linear;
      });
      return denominator > 0 ? numerator / denominator : 0;
    }

    function setBandAvgNote(text: string): void {
      els.bandAvgNote.textContent = text;
    }

    interface BandBarRefs {
      bar: HTMLElement;
      val: HTMLElement;
    }

    let bandBarRefs: BandBarRefs[] | null = null;

    function buildBandBars(): void {
      const cols = eqBarColumns();
      const gridHtml = EQ_GRID_DB.map((gridDb) => {
        const bottom = eqBarPercent(gridDb);
        return `<div class="eq-grid-line" style="bottom:${bottom.toFixed(2)}%"><span>${gridDb}</span></div>`;
      }).join('');

      const barsHtml = cols.map((col, i) => {
        const rangeLabel = EQ_BAND_DEFS[i].rangeLabel;
        return (
          `<div class="eq-bar" data-band="${col.key}" style="left:${col.leftPct.toFixed(3)}%;width:${col.widthPct.toFixed(3)}%" title="${rangeLabel}" aria-label="${col.label}: ${rangeLabel}"></div>` +
          `<div class="eq-val" data-band-val="${col.key}" style="left:${col.centerPct.toFixed(3)}%"></div>`
        );
      }).join('');

      els.bandBars.innerHTML = `<div class="eq-grid">${gridHtml}</div>${barsHtml}`;
      els.bandLabels.innerHTML = cols
        .map((col) => `<span class="eq-label" style="left:${col.centerPct.toFixed(3)}%">${col.label}</span>`)
        .join('');

      bandBarRefs = cols.map((col) => ({
        bar: required(els.bandBars.querySelector<HTMLElement>(`.eq-bar[data-band="${col.key}"]`), `.eq-bar[data-band="${col.key}"]`),
        val: required(els.bandBars.querySelector<HTMLElement>(`.eq-val[data-band-val="${col.key}"]`), `.eq-val[data-band-val="${col.key}"]`),
      }));
    }

    function renderBands(bandDbs: number[]): void {
      if (!bandBarRefs) buildBandBars();
      const refs = bandBarRefs as BandBarRefs[];
      const loudest = loudestBandIndex(bandDbs);
      EQ_BAND_DEFS.forEach((_band, i) => {
        const view = bandView(bandDbs[i]);
        const { bar, val } = refs[i];
        bar.style.height = `${view.pct.toFixed(2)}%`;
        bar.classList.toggle('dim', view.dim);
        bar.classList.toggle('loud', i === loudest);
        val.style.bottom = `${barReadoutBottomPct(view.pct).toFixed(2)}%`;
        val.textContent = view.val;
        val.classList.toggle('hot', view.hot);
        val.classList.toggle('dim', view.dim);
      });
    }

    function buildNotes(result: AnalysisResult, preset: PresetConfig): string[] {
      const notes: string[] = [];
      if (result.peakDb > preset.peakTarget) {
        notes.push(`Peaks are landing hot at ${formatDb(result.peakDb)}. Pull the output back before the stream handoff clips.`);
      } else {
        notes.push(`Peak headroom looks healthy at ${formatDb(result.peakDb)}.`);
      }

      const rmsDelta = result.rmsDb - preset.rmsTarget;
      if (rmsDelta > 2) {
        notes.push(`Overall body is dense for ${preset.label.toLowerCase()} (${formatDb(result.rmsDb)}). Expect less breathing room.`);
      } else if (rmsDelta < -3) {
        notes.push(`The feed is reading light at ${formatDb(result.rmsDb)}. It may feel timid unless the downstream chain adds gain.`);
      } else {
        notes.push(`Overall body is sitting near target for ${preset.label.toLowerCase()}.`);
      }

      const clarityRatio = (result.bands.presence - result.bands.lowMid) / 6;
      if (clarityRatio < preset.clarityTarget - 0.35) {
        notes.push('Low-mid energy is winning over presence. That usually reads as muddy speech or a buried worship lead.');
      } else {
        notes.push('Presence is keeping up with the low-mids, so speech clarity should translate better.');
      }

      if (result.correlation < 0.15) {
        notes.push('Stereo correlation is low. Check for phasey wide effects or mismatched left/right processing.');
      } else if (result.correlation > 0.92) {
        notes.push('The image is very mono-compatible. Width is safe, but make sure the mix still feels open enough.');
      } else {
        notes.push('Stereo image looks balanced enough to translate without obvious phase trouble.');
      }

      return notes;
    }

    function gradeResult(result: AnalysisResult, preset: PresetConfig): GradeResult {
      let score = 100;
      score -= clamp((result.peakDb - preset.peakTarget) * 10, 0, 25);
      score -= Math.abs(result.rmsDb - preset.rmsTarget) * 3.5;
      score -= Math.abs(result.dynamicRange - preset.dynamicTarget) * 2.2;
      score -= Math.abs(result.balanceDb) * 4;
      score -= clamp((0.2 - result.correlation) * 28, 0, 18);
      score -= Math.abs(result.centroid - preset.centroidTarget) / 280;

      const clarityRatio = (result.bands.presence - result.bands.lowMid) / 6;
      score -= Math.abs(clarityRatio - preset.clarityTarget) * 10;
      score = Math.round(clamp(score, 42, 99));

      let letter = 'B';
      if (score >= 94) letter = 'A';
      else if (score >= 86) letter = 'B';
      else if (score >= 76) letter = 'C';
      else if (score >= 66) letter = 'D';
      else letter = 'F';

      return { score, letter };
    }

    function meterWidth(value: number, min: number, max: number): string {
      return `${clamp(((value - min) / (max - min)) * 100, 0, 100)}%`;
    }

    function buildSummaryText(result: AnalysisResult, preset: PresetConfig, grade: GradeResult, notes: string[]): string {
      const liveLevelLine =
        result.source === 'Live stereo input' && state.liveLevelDb !== null
          ? [
              `Live level: ${formatDb(state.liveLevelDb)} (${WEIGHTING_LABELS[state.weighting]}, ` +
                `${state.response}, ${evaluateRange(state.liveLevelDb, preset.liveTarget)} target window)`,
            ]
          : [];

      return [
        `Sound Buddy Browser Lite — ${preset.label}`,
        `Source: ${result.source}`,
        `Quick grade: ${grade.letter} (${grade.score}/100)`,
        `Peak: ${formatDb(result.peakDb)}`,
        `Body: ${formatDb(result.rmsDb)}`,
        `Stereo correlation: ${result.correlation.toFixed(2)}`,
        `Balance: ${result.balanceDb.toFixed(1)} dB L-R`,
        `Dynamic spread: ${result.dynamicRange.toFixed(1)} dB`,
        `Centroid: ${formatHz(result.centroid)}`,
        ...liveLevelLine,
        '',
        ...notes.map((note) => `- ${note}`),
      ].join('\n');
    }

    function applyResult(result: AnalysisResult): void {
      const presetKey = els.preset.value;
      const preset = isPresetKey(presetKey) ? PRESETS[presetKey] : PRESETS.worship;
      const grade = gradeResult(result, preset);
      const notes = buildNotes(result, preset);
      state.lastResult = result;
      state.summaryText = buildSummaryText(result, preset, grade, notes);

      els.copySummary.disabled = false;
      els.gradeLetter.textContent = grade.letter;
      els.gradeScore.textContent = `${grade.score} / 100`;
      els.gradeNote.textContent = notes[0];
      els.peak.textContent = formatDb(result.peakDb);
      els.rms.textContent = formatDb(result.rmsDb);
      els.correlation.textContent = result.correlation.toFixed(2);
      els.peakBar.style.width = meterWidth(result.peakDb, -24, 0);
      els.rmsBar.style.width = meterWidth(result.rmsDb, -36, -8);
      els.correlationBar.style.width = meterWidth(result.correlation, -1, 1);

      els.summaryList.innerHTML = notes.map((note) => `<li>${note}</li>`).join('');
      renderBands(EQ_BAND_DEFS.map((band) => result.bands[band.key]));

      els.source.textContent = result.source;
      els.duration.textContent = formatSeconds(result.duration);
      els.sampleRate.textContent = `${Math.round(result.sampleRate / 1000)} kHz`;
      els.balance.textContent = `${result.balanceDb.toFixed(1)} dB`;
      els.dynamic.textContent = `${result.dynamicRange.toFixed(1)} dB`;
      els.centroid.textContent = formatHz(result.centroid);
      els.copyStatus.textContent = 'Copy notes is ready.';
    }

    async function populateDevices(): Promise<void> {
      if (!navigator.mediaDevices?.enumerateDevices) return;
      const devices = await navigator.mediaDevices.enumerateDevices();
      const inputs = devices.filter((device) => device.kind === 'audioinput');
      const options = ['<option value="">Default input</option>']
        .concat(inputs.map((device) => `<option value="${device.deviceId}">${device.label || 'Audio input'}</option>`));
      els.device.innerHTML = options.join('');
    }

    function stopLive(): void {
      cancelAnimationFrame(state.animationFrame);
      state.animationFrame = 0;
      if (state.stream) {
        state.stream.getTracks().forEach((track) => track.stop());
      }
      state.stream = null;
      if (state.audioContext && state.audioContext.state !== 'closed') {
        void state.audioContext.close();
      }
      state.audioContext = null;
      state.levelSmoother.reset();
      state.lastTickMs = null;
      state.bandAverager.reset();
      state.scalarAverager.reset();
      state.rmsAverager.reset();
      state.peakHold.reset();
      renderLiveLevel(null);
      setBandAvgNote('Waiting for audio');
      els.stopLive.disabled = true;
      els.startLive.disabled = false;
      els.runMode.textContent = 'Idle';
      els.statusCopy.textContent = 'Live check stopped.';
    }

    async function startLive(): Promise<void> {
      stopLive();
      const constraints: MediaStreamConstraints = {
        audio: {
          channelCount: { ideal: 2, min: 1 },
          echoCancellation: false,
          noiseSuppression: false,
          autoGainControl: false,
          ...(els.device.value ? { deviceId: { exact: els.device.value } } : {}),
        },
      };

      try {
        state.stream = await navigator.mediaDevices.getUserMedia(constraints);
      } catch {
        els.statusCopy.textContent =
          'Microphone access was blocked. Allow microphone permission for this site in your browser settings, then try again.';
        return;
      }
      await populateDevices();

      const context = new AudioContext();
      state.audioContext = context;
      const source = context.createMediaStreamSource(state.stream);
      const splitter = context.createChannelSplitter(2);
      const leftAnalyser = context.createAnalyser();
      const rightAnalyser = context.createAnalyser();
      const merger = context.createChannelMerger(2);
      const monoAnalyser = context.createAnalyser();
      const startedAt = performance.now();

      leftAnalyser.fftSize = 2048;
      rightAnalyser.fftSize = 2048;
      monoAnalyser.fftSize = 2048;

      source.connect(splitter);
      splitter.connect(leftAnalyser, 0);
      splitter.connect(rightAnalyser, 1);
      splitter.connect(merger, 0, 0);
      splitter.connect(merger, 1, 1);
      merger.connect(monoAnalyser);

      const leftFreq = new Float32Array(leftAnalyser.frequencyBinCount);
      const rightFreq = new Float32Array(rightAnalyser.frequencyBinCount);
      const avgFreq = new Float32Array(leftAnalyser.frequencyBinCount);
      const leftTime = new Float32Array(leftAnalyser.fftSize);
      const rightTime = new Float32Array(rightAnalyser.fftSize);

      const tick = (nowMs: number) => {
        leftAnalyser.getFloatFrequencyData(leftFreq);
        rightAnalyser.getFloatFrequencyData(rightFreq);
        leftAnalyser.getFloatTimeDomainData(leftTime);
        rightAnalyser.getFloatTimeDomainData(rightTime);

        const sampleRate = context.sampleRate;
        const binHz = sampleRate / 2 / leftFreq.length;

        for (let i = 0; i < leftFreq.length; i += 1) {
          avgFreq[i] = (leftFreq[i] + rightFreq[i]) * 0.5;
        }

        const instBandDbs = EQ_BAND_DEFS.map((band) => {
          let sum = 0;
          let count = 0;
          for (let i = 0; i < leftFreq.length; i += 1) {
            const hz = i * binHz;
            if (hz >= band.lo && hz < band.hi) {
              sum += avgFreq[i];
              count += 1;
            }
          }
          return count ? sum / count : -90;
        });

        const rmsDbValue = db(computeRms(downmix(leftTime, rightTime)));
        const peakDbValue = db(computePeak(leftTime, rightTime));
        const instCorrelation = computeCorrelation(leftTime, rightTime);
        const instBalanceDb = computeBalanceDb(leftTime, rightTime);

        // Live values are smoothed with a rolling average window (#299) so the
        // band balance and hero meters read as a settled measurement rather
        // than a jittery instantaneous FFT frame — this is a different kind
        // of smoothing than the live level meter's slow/fast ballistics below.
        const avgBandDbs = state.bandAverager.update(instBandDbs, nowMs);
        const [avgCorrelation, avgBalanceDb] = state.scalarAverager.update([instCorrelation, instBalanceDb], nowMs);
        const [avgRmsDb] = state.rmsAverager.update([rmsDbValue], nowMs);
        const avgPeakDb = state.peakHold.update(peakDbValue, nowMs);
        const bandsRecord = Object.fromEntries(
          EQ_BAND_DEFS.map((band, i) => [band.key, avgBandDbs[i]]),
        ) as Record<BandKey, number>;

        const latestResult: AnalysisResult = {
          source: 'Live stereo input',
          duration: (performance.now() - startedAt) / 1000,
          sampleRate,
          peakDb: avgPeakDb,
          rmsDb: avgRmsDb,
          correlation: avgCorrelation,
          balanceDb: avgBalanceDb,
          dynamicRange: Math.max(0, avgPeakDb - avgRmsDb),
          centroid: centroidFromBandDbs(avgBandDbs),
          bands: bandsRecord,
        };

        // The AnalyserNode's own smoothingTimeConstant (default 0.8, ~frame-level)
        // sits underneath our explicit slow/fast ballistics below — it is
        // negligible versus the 1 s slow time constant, so the analysers'
        // settings are left untouched (the band-balance display depends on them).
        const correctionDb = weightingCorrectionDb(avgFreq, binHz, state.weighting);
        const instantDb = rmsDbValue + correctionDb;
        const dtMs = state.lastTickMs === null ? 0 : nowMs - state.lastTickMs;
        state.lastTickMs = nowMs;
        const displayDb = state.levelSmoother.update(instantDb, dtMs);
        renderLiveLevel(displayDb);

        applyResult(latestResult);

        const coverageMs = state.bandAverager.coverageMs(nowMs);
        setBandAvgNote(
          coverageMs < LIVE_AVG_WINDOW_MS
            ? `Settling · averaging first ${LIVE_AVG_WINDOW_MS / 1000}s`
            : '3-second rolling average · live',
        );

        els.runMode.textContent = 'Live';
        els.statusCopy.textContent = 'Listening locally — values are a 3-second rolling average.';
        state.animationFrame = requestAnimationFrame(tick);
      };

      els.startLive.disabled = true;
      els.stopLive.disabled = false;
      renderLiveLevelMode();
      renderLiveTargetBand();
      tick(performance.now());
    }

    els.file.addEventListener('change', (event) => {
      const target = event.target as HTMLInputElement;
      const file = target.files?.[0];
      if (!file) return;
      void (async () => {
        els.runMode.textContent = 'Analyzing';
        els.statusCopy.textContent = `Decoding ${file.name} locally...`;
        const context = new AudioContext();
        try {
          const data = await file.arrayBuffer();
          const buffer = await context.decodeAudioData(data.slice(0));
          await analyzeDecodedBuffer(buffer, file.name);
          els.runMode.textContent = 'File';
          els.statusCopy.textContent = `${file.name} analyzed locally in your browser.`;
        } catch {
          els.runMode.textContent = 'Idle';
          els.statusCopy.textContent =
            `Couldn't decode ${file.name}. Try a standard stereo WAV, AIFF, MP3, AAC, or M4A file.`;
        } finally {
          await context.close();
        }
      })();
    });

    els.refreshDevices.addEventListener('click', () => {
      void populateDevices();
    });

    els.startLive.addEventListener('click', () => {
      void startLive();
    });

    els.stopLive.addEventListener('click', () => {
      stopLive();
    });

    els.copySummary.addEventListener('click', () => {
      if (!state.summaryText) return;
      void navigator.clipboard.writeText(state.summaryText).then(() => {
        els.copyStatus.textContent = 'Copied. Paste it straight into your team chat.';
      });
    });

    els.preset.addEventListener('change', () => {
      if (state.lastResult) applyResult(state.lastResult);
      renderLiveTargetBand();
      if (state.liveLevelDb !== null) renderLiveLevel(state.liveLevelDb);
    });

    els.weighting.addEventListener('change', () => {
      const value = els.weighting.value;
      if (!isWeighting(value)) return;
      state.weighting = value;
      state.levelSmoother.reset();
      state.lastTickMs = null;
      renderLiveLevelMode();
    });

    els.response.addEventListener('change', () => {
      const value = els.response.value;
      if (!isMeterResponse(value)) return;
      state.response = value;
      state.levelSmoother = createLevelSmoother(RESPONSE_TIME_CONSTANTS_MS[value]);
      state.lastTickMs = null;
      renderLiveLevelMode();
    });

    window.addEventListener('beforeunload', stopLive);
    void populateDevices();
    renderLiveLevelMode();
    renderLiveTargetBand();
  })();
</script>

