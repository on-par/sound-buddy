---
// Shared chrome for the static legal pages (/refund, /terms, /privacy):
// a minimal brand header, a readable prose column, and a footer that links
// the three policies together. Wraps the base Layout so fonts, tokens, and
// global styles match the landing page.
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  /** Human date the policy was last updated, e.g. "July 7, 2026". */
  updated: string;
  /** Eyebrow label above the title — defaults to "Legal" for the policy pages. */
  eyebrow?: string;
}
const { title, description, updated, eyebrow = 'Legal' } = Astro.props;

const HOME_URL = '/';
const SUPPORT_EMAIL = 'support@soundbuddy.online';

const legalLinks = [
  { href: '/refund', label: 'Refund Policy' },
  { href: '/terms', label: 'Terms of Service' },
  { href: '/privacy', label: 'Privacy Policy' },
];
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
// Per-page canonical (Astro.site is set in astro.config), so /refund, /terms,
// and /privacy aren't reported as duplicates of the homepage.
const canonical = new URL(current, Astro.site).href;
---

<Layout title={`${title} — Sound Buddy`} description={description} canonical={canonical}>
  <header class="site-header">
    <div class="container header-row">
      <a class="brand" href={HOME_URL} aria-label="Sound Buddy home">
        <span class="brand-mark" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <circle cx="11" cy="11" r="9.5" stroke="var(--gold-500)" stroke-width="1.5" />
            <circle cx="11" cy="11" r="3.2" fill="var(--gold-500)" />
          </svg>
        </span>
        <span class="brand-name">Sound Buddy</span>
      </a>
      <a class="back-link" href={HOME_URL}>← Back to site</a>
    </div>
  </header>

  <main class="legal">
    <div class="container legal-container">
      <span class="eyebrow">{eyebrow}</span>
      <h1 class="legal-title">{title}</h1>
      <p class="legal-updated mono">Last updated {updated}</p>
      <div class="prose">
        <slot />
      </div>
      <p class="legal-contact">
        Questions? Email <a href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>.
      </p>
    </div>
  </main>

  <footer class="site-footer">
    <div class="container footer-row">
      <div class="footer-brand">
        <span class="brand-mark" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 22 22" fill="none">
            <circle cx="11" cy="11" r="9.5" stroke="var(--gold-500)" stroke-width="1.5" />
            <circle cx="11" cy="11" r="3.2" fill="var(--gold-500)" />
          </svg>
        </span>
        <span>Sound Buddy</span>
      </div>
      <nav class="footer-nav" aria-label="Legal">
        {legalLinks.map((l) => (
          <a href={l.href} aria-current={current === l.href ? 'page' : undefined}>{l.label}</a>
        ))}
      </nav>
      <p class="footer-meta mono">© {new Date().getFullYear()} <a href="https://onpardev.com" rel="noopener">On PAR Dev</a> · Built for worship teams</p>
    </div>
  </footer>
</Layout>

<style>
  /* ── Header ── */
  .site-header { position: sticky; top: 0; z-index: 10; background: color-mix(in srgb, var(--bg-app) 88%, transparent); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border-subtle); }
  .header-row { display: flex; align-items: center; gap: 20px; height: 64px; }
  .brand { display: inline-flex; align-items: center; gap: 9px; font: var(--fw-semibold) var(--fs-body-lg)/1 var(--font-sans); color: var(--text-primary); }
  .brand-mark { display: inline-flex; }
  .back-link { margin-left: auto; font: var(--fw-medium) var(--fs-body-sm)/1 var(--font-sans); color: var(--text-secondary); padding: 6px 0; border-bottom: 1px solid transparent; transition: color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out); }
  .back-link:hover { color: var(--text-primary); border-bottom-color: var(--gold-500); }

  /* ── Prose column ── */
  .legal { padding: 64px 0 88px; }
  .legal-container { max-width: 720px; }
  .legal-title { font: var(--fw-bold) var(--fs-h1)/var(--lh-tight) var(--font-sans); letter-spacing: var(--tracking-tight); color: var(--text-primary); margin: 10px 0 6px; }
  .legal-updated { color: var(--text-muted); font-size: var(--fs-label); }
  .legal-contact { margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border-subtle); font: var(--fw-regular) var(--fs-body-sm)/var(--lh-relaxed) var(--font-sans); color: var(--text-tertiary); }
  .legal-contact a, .prose :global(a) { color: var(--gold-text); border-bottom: 1px solid var(--border-subtle); }
  .legal-contact a:hover, .prose :global(a:hover) { border-bottom-color: var(--gold-500); }

  /* The policy body is authored as plain HTML in each page; style it here. */
  .prose { margin-top: 32px; color: var(--text-secondary); font: var(--fw-regular) var(--fs-body-lg)/var(--lh-relaxed) var(--font-sans); }
  .prose :global(h2) { font: var(--fw-semibold) var(--fs-h2)/var(--lh-snug) var(--font-sans); color: var(--text-primary); margin: 36px 0 12px; letter-spacing: var(--tracking-tight); }
  .prose :global(h2:first-child) { margin-top: 0; }
  .prose :global(p) { margin: 0 0 16px; }
  .prose :global(ul) { margin: 0 0 16px; padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .prose :global(li) { position: relative; padding-left: 22px; }
  .prose :global(li)::before { content: ''; position: absolute; left: 2px; top: 10px; width: 7px; height: 7px; border-radius: 50%; background: var(--gold-500); }
  .prose :global(strong) { color: var(--text-primary); font-weight: var(--fw-semibold); }
  .prose :global(.callout) { margin: 24px 0; padding: 20px 22px; border: 1px solid var(--good-border); background: var(--good-tint); border-radius: var(--radius-lg); color: var(--text-secondary); }
  .prose :global(.callout strong) { color: var(--good-text); }

  /* ── Footer (mirrors index.astro) ── */
  .site-footer { border-top: 1px solid var(--border-subtle); background: var(--neutral-1000); padding: 36px 0; }
  .footer-row { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
  .footer-brand { display: inline-flex; align-items: center; gap: 8px; font: var(--fw-semibold) var(--fs-body)/1 var(--font-sans); color: var(--text-primary); }
  .footer-nav { display: flex; gap: 20px; margin-left: auto; flex-wrap: wrap; font: var(--fw-medium) var(--fs-body-sm)/1 var(--font-sans); color: var(--text-tertiary); }
  .footer-nav a { border-bottom: 1px solid transparent; padding-bottom: 2px; }
  .footer-nav a:hover { color: var(--text-primary); }
  .footer-nav a[aria-current='page'] { color: var(--gold-text); }
  .footer-meta { font-size: var(--fs-micro); color: var(--text-muted); }
  .footer-meta a { color: inherit; text-decoration: none; }
  .footer-meta a:hover { color: var(--text-primary); }

  @media (max-width: 720px) {
    .legal { padding: 44px 0 56px; }
  }
</style>
