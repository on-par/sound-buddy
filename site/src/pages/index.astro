---
import Layout from '../layouts/Layout.astro';
import ReportCard from '../components/ReportCard.astro';

const DOWNLOAD_URL = 'https://github.com/on-par/sound-buddy-releases/releases/latest';
const REPO_URL = 'https://github.com/on-par/sound-buddy';

const steps = [
  { n: '1', title: 'Record your service', body: 'Capture every channel straight from your interface — up to 32 inputs, stems saved per strip.' },
  { n: '2', title: 'Drop the file in', body: 'Sound Buddy analyzes loudness, dynamics, spectral balance, and speech vs. music — fully on your Mac.' },
  { n: '3', title: 'Get your report card', body: 'A letter grade plus the exact things to fix. Virtual soundcheck lets you replay the room as separate tracks.' },
];

const tiers = [
  {
    name: 'Free',
    price: '$0',
    cadence: 'forever',
    blurb: 'For the volunteer running Sunday once a week.',
    cta: 'Download',
    ctaHref: DOWNLOAD_URL,
    ctaVariant: 'ghost',
    features: ['Record up to 8 channels', 'Full report card + letter grade', 'Spectral & dynamics analysis', 'Virtual soundcheck playback'],
  },
  {
    name: 'Pro Monthly',
    price: '$9',
    cadence: '/ month',
    blurb: 'For the engineer who wants every channel, every week.',
    cta: 'Download — start 14-day trial',
    ctaHref: DOWNLOAD_URL,
    ctaVariant: 'primary',
    featured: true,
    features: ['Record up to 32 channels', 'Per-strip stems + session manifest', 'AI analyst on your local Ollama', 'Channel groups, rigs & profiles', 'Priority email support'],
  },
  {
    name: 'Pro Annual',
    price: '$79',
    cadence: '/ year',
    blurb: 'Two months free. Built for the church budget cycle.',
    cta: 'Download — start 14-day trial',
    ctaHref: DOWNLOAD_URL,
    ctaVariant: 'ghost',
    features: ['Everything in Pro Monthly', 'Save ~$29 vs. monthly', 'Single PO / receipt for finance', 'All future Pro features included'],
  },
];
---

<Layout>
  <!-- ── Header ─────────────────────────────────────────────────── -->
  <header class="site-header">
    <div class="container header-row">
      <a class="brand" href="/" aria-label="Sound Buddy home">
        <span class="brand-mark" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <circle cx="11" cy="11" r="9.5" stroke="var(--gold-500)" stroke-width="1.5" />
            <circle cx="11" cy="11" r="3.2" fill="var(--gold-500)" />
          </svg>
        </span>
        <span class="brand-name">Sound Buddy</span>
      </a>
      <nav class="header-nav" aria-label="Primary">
        <a href="#how">How it works</a>
        <a href="#report-card">Report card</a>
        <a href="#pricing">Pricing</a>
        <a href={REPO_URL} rel="noopener">GitHub</a>
      </nav>
      <a class="btn btn-primary" href={DOWNLOAD_URL} rel="noopener">Download</a>
    </div>
  </header>

  <!-- ── Hero ───────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Built for worship services</span>
        <h1>See your mix. Score it. Improve it.</h1>
        <p class="hero-lede">
          Sound Buddy records your service, grades the mix, and shows you exactly what to fix —
          loudness, dynamics, spectral balance, and speech clarity. Runs fully on your Mac.
          Your audio never leaves your machine.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary btn-lg" href={DOWNLOAD_URL} rel="noopener">Download for Mac</a>
          <a class="btn btn-ghost btn-lg" href="#how">See how it works</a>
        </div>
        <p class="hero-fine mono">Apple Silicon · macOS 26+ · v0.6.0</p>
      </div>
      <div class="hero-visual">
        <ReportCard />
      </div>
    </div>
  </section>

  <!-- ── Trust bar ──────────────────────────────────────────────── -->
  <section class="trust tight">
    <div class="container trust-grid">
      <div class="trust-item">
        <span class="trust-icon" aria-hidden="true">⌁</span>
        <div>
          <strong>Works with your existing AI.</strong>
          <p>Bring Ollama, or paste an API key. Sound Buddy meets you where you are.</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon" aria-hidden="true">🔒</span>
        <div>
          <strong>No cloud. No accounts. No data collection.</strong>
          <p>Analysis runs on-device. Your recordings stay on your Mac, full stop.</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon" aria-hidden="true">♩</span>
        <div>
          <strong>Built by live-sound engineers.</strong>
          <p>For the volunteer and the staff audio lead at the church FOH desk.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── How it works ───────────────────────────────────────────── -->
  <section id="how" class="section">
    <div class="container">
      <span class="eyebrow">How it works</span>
      <h2 class="h2">From service to report card in three steps.</h2>
      <div class="steps">
        {steps.map((s) => (
          <div class="step card">
            <span class="step-n mono">{s.n}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Report card showcase ───────────────────────────────────── -->
  <section id="report-card" class="section rc-showcase">
    <div class="container rc-showcase-grid">
      <div class="rc-showcase-copy">
        <span class="eyebrow">The aha moment</span>
        <h2 class="h2">A letter grade for the whole service — and the levers to pull.</h2>
        <p class="lede">
          Every service gets a grade, a content timeline (speech, music, silence), and a metric
          table that points at what to change next week. Bass running hot? Speech buried?
          Sound Buddy names it, so you can fix it.
        </p>
        <ul class="rc-bullets">
          <li>Loudness, true peak &amp; dynamic range against real targets</li>
          <li>Spectral balance across seven bands</li>
          <li>Speech-intelligibility estimate for the spoken word</li>
          <li>Virtual soundcheck — replay the room as separate stems</li>
        </ul>
      </div>
      <div class="rc-showcase-visual">
        <ReportCard />
      </div>
    </div>
  </section>

  <!-- ── Pricing ────────────────────────────────────────────────── -->
  <section id="pricing" class="section pricing">
    <div class="container">
      <span class="eyebrow">Pricing</span>
      <h2 class="h2">Free to start. Pro when you're ready.</h2>
      <p class="lede">14-day Pro trial on first launch — no card, no account. Local-first on every tier.</p>
      <div class="tiers">
        {tiers.map((t) => (
          <div class={`tier card ${t.featured ? 'featured' : ''}`}>
            {t.featured && <span class="tier-flag">Most popular</span>}
            <h3>{t.name}</h3>
            <div class="tier-price"><span class="price">{t.price}</span><span class="cadence">{t.cadence}</span></div>
            <p class="tier-blurb">{t.blurb}</p>
            <a class={`btn ${t.ctaVariant === 'primary' ? 'btn-primary' : 'btn-ghost'}`} href={t.ctaHref} rel="noopener">{t.cta}</a>
            <ul class="tier-features">
              {t.features.map((f) => <li>{f}</li>)}
            </ul>
          </div>
        ))}
      </div>
      <p class="pricing-note">
        Refunds, terms &amp; privacy: see our <a href={REPO_URL} rel="noopener">legal pages</a>.
        Pricing set with the church budget cycle in mind.
      </p>
    </div>
  </section>

  <!-- ── Privacy callout ────────────────────────────────────────── -->
  <section class="section privacy">
    <div class="container privacy-card card">
      <span class="eyebrow">Privacy</span>
      <h2 class="h2">Your audio never leaves your machine.</h2>
      <p class="lede">
        No cloud uploads. No accounts. No analytics tracking you across the web. Sound Buddy does
        its analysis on-device — that's the whole point. If you opt into AI, you pick the provider
        (Ollama locally, or your own API key). Nothing is sent anywhere by default.
      </p>
      <div class="privacy-pills">
        <span class="pill good">No cloud</span>
        <span class="pill good">No accounts</span>
        <span class="pill good">No data collection</span>
        <span class="pill info">Optional local AI</span>
      </div>
    </div>
  </section>

  <!-- ── System requirements ────────────────────────────────────── -->
  <section class="section tight sysreq">
    <div class="container sysreq-grid">
      <div>
        <span class="eyebrow">System requirements</span>
        <h2 class="h2">Runs on the Mac you already own.</h2>
        <ul class="sysreq-list">
          <li><strong>Mac</strong> — Apple Silicon (M1 or newer)</li>
          <li><strong>macOS</strong> — 26 (Tahoe) or newer</li>
          <li><strong>Audio interface</strong> — any Core Audio device, up to 32 inputs</li>
          <li><strong>Disk</strong> — ~5 GB for the app + room for recordings</li>
        </ul>
      </div>
      <div class="sysreq-cta card">
        <h3>Ready to grade your next service?</h3>
        <p>Download Sound Buddy and get a report card from this Sunday's recording in under five minutes.</p>
        <a class="btn btn-primary btn-lg" href={DOWNLOAD_URL} rel="noopener">Download for Mac</a>
      </div>
    </div>
  </section>

  <!-- ── Footer ─────────────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="container footer-row">
      <div class="footer-brand">
        <span class="brand-mark" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 22 22" fill="none">
            <circle cx="11" cy="11" r="9.5" stroke="var(--gold-500)" stroke-width="1.5" />
            <circle cx="11" cy="11" r="3.2" fill="var(--gold-500)" />
          </svg>
        </span>
        <span>Sound Buddy</span>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        <a href={DOWNLOAD_URL} rel="noopener">Download</a>
        <a href={REPO_URL} rel="noopener">GitHub</a>
        <a href="#pricing">Pricing</a>
        <a href={`mailto:support@soundbuddy.online`}>Support</a>
      </nav>
      <p class="footer-meta mono">© 2026 On Par · Built for worship teams</p>
    </div>
  </footer>
</Layout>

<style>
  /* ── Header ── */
  .site-header { position: sticky; top: 0; z-index: 10; background: color-mix(in srgb, var(--bg-app) 88%, transparent); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border-subtle); }
  .header-row { display: flex; align-items: center; gap: 20px; height: 64px; }
  .brand { display: inline-flex; align-items: center; gap: 9px; font: var(--fw-semibold) var(--fs-body-lg)/1 var(--font-sans); color: var(--text-primary); }
  .brand-mark { display: inline-flex; }
  .header-nav { display: flex; gap: 22px; margin-left: auto; font: var(--fw-medium) var(--fs-body-sm)/1 var(--font-sans); color: var(--text-secondary); }
  .header-nav a { padding: 6px 0; border-bottom: 1px solid transparent; transition: color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out); }
  .header-nav a:hover { color: var(--text-primary); border-bottom-color: var(--gold-500); }
  .site-header .btn { height: 36px; padding: 0 16px; }

  /* ── Hero ── */
  .hero { padding: 72px 0 88px; background:
      radial-gradient(900px 480px at 78% 0%, var(--gold-tint-soft), transparent 70%),
      radial-gradient(700px 420px at 12% 12%, var(--azure-tint), transparent 72%); }
  .hero-grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: 56px; align-items: center; }
  .hero-copy h1 { font: var(--fw-bold) var(--fs-display)/var(--lh-tight) var(--font-sans); letter-spacing: var(--tracking-tight); margin: 16px 0 18px; color: var(--text-primary); }
  .hero-lede { font: var(--fw-regular) var(--fs-h3)/var(--lh-relaxed) var(--font-sans); color: var(--text-secondary); max-width: 52ch; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .hero-fine { margin-top: 18px; color: var(--text-muted); font-size: var(--fs-label); }
  .hero-visual { display: flex; justify-content: center; }
  .hero-visual :global(.rc) { width: 100%; max-width: 460px; transform: rotate(-0.4deg); box-shadow: var(--shadow-lg); }

  /* ── Trust bar ── */
  .trust { background: var(--bg-panel); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle); }
  .trust-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; padding: 36px 24px; }
  .trust-item { display: flex; gap: 14px; align-items: flex-start; }
  .trust-icon { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: var(--radius-md); background: var(--gold-tint); color: var(--gold-text); font-size: 18px; flex-shrink: 0; }
  .trust-item strong { display: block; font: var(--fw-semibold) var(--fs-body-sm)/var(--lh-snug) var(--font-sans); color: var(--text-primary); margin-bottom: 4px; }
  .trust-item p { font: var(--fw-regular) var(--fs-body-sm)/var(--lh-normal) var(--font-sans); color: var(--text-tertiary); }

  /* ── How it works ── */
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 36px; }
  .step { padding: 26px 24px; }
  .step-n { display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: var(--radius-md); background: var(--gold-tint); color: var(--gold-text); font: var(--fw-semibold) var(--fs-body)/1 var(--font-mono); margin-bottom: 14px; }
  .step h3 { font: var(--fw-semibold) var(--fs-h2)/var(--lh-snug) var(--font-sans); color: var(--text-primary); margin-bottom: 8px; }
  .step p { font: var(--fw-regular) var(--fs-body-sm)/var(--lh-normal) var(--font-sans); color: var(--text-tertiary); }

  /* ── Report card showcase ── */
  .rc-showcase { background: var(--bg-panel-2); }
  .rc-showcase-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
  .rc-bullets { list-style: none; margin-top: 22px; display: flex; flex-direction: column; gap: 12px; }
  .rc-bullets li { position: relative; padding-left: 24px; font: var(--fw-regular) var(--fs-body-sm)/var(--lh-normal) var(--font-sans); color: var(--text-secondary); }
  .rc-bullets li::before { content: ''; position: absolute; left: 0; top: 8px; width: 8px; height: 8px; border-radius: 50%; background: var(--gold-500); }
  .rc-showcase-visual { display: flex; justify-content: center; }
  .rc-showcase-visual :global(.rc) { width: 100%; max-width: 480px; box-shadow: var(--shadow-lg); }

  /* ── Pricing ── */
  .pricing { background: var(--bg-app); }
  .tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 36px; }
  .tier { padding: 28px 26px; display: flex; flex-direction: column; gap: 14px; position: relative; }
  .tier.featured { border-color: var(--gold-500); box-shadow: var(--elevation-card), var(--glow-gold); }
  .tier-flag { position: absolute; top: -11px; left: 26px; background: var(--gold-500); color: var(--text-on-accent); font: var(--fw-semibold) var(--fs-micro)/1 var(--font-sans); letter-spacing: var(--tracking-caps); text-transform: uppercase; padding: 4px 10px; border-radius: var(--radius-pill); }
  .tier h3 { font: var(--fw-semibold) var(--fs-h2)/1 var(--font-sans); color: var(--text-primary); }
  .tier-price { display: flex; align-items: baseline; gap: 8px; }
  .tier-price .price { font: var(--fw-bold) var(--fs-data-xl)/1 var(--font-sans); color: var(--text-primary); }
  .tier-price .cadence { font: var(--fw-regular) var(--fs-body-sm)/1 var(--font-sans); color: var(--text-muted); }
  .tier-blurb { font: var(--fw-regular) var(--fs-body-sm)/var(--lh-normal) var(--font-sans); color: var(--text-tertiary); min-height: 2.6em; }
  .tier .btn { width: 100%; }
  .tier-features { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-top: 6px; padding-top: 16px; border-top: 1px solid var(--border-subtle); }
  .tier-features li { position: relative; padding-left: 22px; font: var(--fw-regular) var(--fs-body-sm)/var(--lh-normal) var(--font-sans); color: var(--text-secondary); }
  .tier-features li::before { content: '✓'; position: absolute; left: 0; top: 0; color: var(--good-text); font: var(--fw-semibold) var(--fs-body-sm)/1 var(--font-sans); }
  .pricing-note { margin-top: 24px; font: var(--fw-regular) var(--fs-body-sm)/1.5 var(--font-sans); color: var(--text-muted); text-align: center; }
  .pricing-note a { color: var(--gold-text); border-bottom: 1px solid var(--border-subtle); }

  /* ── Privacy ── */
  .privacy-card { padding: 44px 40px; text-align: center; }
  .privacy-card .eyebrow, .privacy-card .h2, .privacy-card .lede { display: block; margin-left: auto; margin-right: auto; }
  .privacy-card .lede { text-align: center; }
  .privacy-pills { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-top: 24px; }
  .pill { display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; border-radius: var(--radius-pill); font: var(--fw-semibold) var(--fs-label)/1 var(--font-sans); letter-spacing: var(--tracking-caps); }
  .pill.good { background: var(--good-tint); border: 1px solid var(--good-border); color: var(--good-text); }
  .pill.info { background: var(--info-tint); border: 1px solid var(--info-border); color: var(--info-text); }

  /* ── Sysreq / CTA ── */
  .sysreq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
  .sysreq-list { list-style: none; margin-top: 22px; display: flex; flex-direction: column; gap: 12px; }
  .sysreq-list li { font: var(--fw-regular) var(--fs-body-sm)/var(--lh-normal) var(--font-sans); color: var(--text-secondary); }
  .sysreq-list strong { color: var(--text-primary); font-weight: var(--fw-semibold); }
  .sysreq-cta { padding: 36px 32px; display: flex; flex-direction: column; gap: 14px; align-items: flex-start; }
  .sysreq-cta h3 { font: var(--fw-semibold) var(--fs-h2)/var(--lh-snug) var(--font-sans); color: var(--text-primary); }
  .sysreq-cta p { font: var(--fw-regular) var(--fs-body-sm)/var(--lh-normal) var(--font-sans); color: var(--text-tertiary); }

  /* ── Footer ── */
  .site-footer { border-top: 1px solid var(--border-subtle); background: var(--neutral-1000); padding: 36px 0; }
  .footer-row { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
  .footer-brand { display: inline-flex; align-items: center; gap: 8px; font: var(--fw-semibold) var(--fs-body)/1 var(--font-sans); color: var(--text-primary); }
  .footer-nav { display: flex; gap: 20px; margin-left: auto; font: var(--fw-medium) var(--fs-body-sm)/1 var(--font-sans); color: var(--text-tertiary); }
  .footer-nav a:hover { color: var(--text-primary); }
  .footer-meta { font-size: var(--fs-micro); color: var(--text-muted); }

  /* ── Responsive ── */
  @media (max-width: 920px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-visual { order: -1; }
    .hero-visual :global(.rc) { max-width: 100%; }
    .rc-showcase-grid { grid-template-columns: 1fr; gap: 40px; }
    .tiers { grid-template-columns: 1fr; max-width: 460px; margin-left: auto; margin-right: auto; }
    .sysreq-grid { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 720px) {
    .header-nav { display: none; }
    .hero-copy h1 { font-size: 40px; }
    .trust-grid { grid-template-columns: 1fr; gap: 24px; }
    .steps { grid-template-columns: 1fr; }
    .privacy-card { padding: 28px 20px; }
  }
</style>
