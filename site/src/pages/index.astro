---
import Layout from '../layouts/Layout.astro';
import BrandMark from '../components/BrandMark.astro';
import ReportCard from '../components/ReportCard.astro';
import BrowserLitePreview from '../components/BrowserLitePreview.astro';
import liveCaptureScreenshot from '../assets/screenshots/live-capture.png';
import reportCardShot from '../assets/screenshots/report-card.png';
import momentumShot from '../assets/screenshots/momentum.png';
import { GUARANTEE_BADGE, REFUND_PATH } from '../lib/guarantee';
import { FOUNDING_CAP, foundingCheckoutUrl, foundingUrgency, isCheckoutLive } from '../lib/founding-urgency';
import { FAQ_ENTRIES } from '../lib/faq';

const DOWNLOAD_URL = '/download';
const REPO_URL = 'https://github.com/on-par/sound-buddy';
const BROWSER_URL = '/browser';
const FOUNDING_URL = foundingCheckoutUrl(process.env);

// Single source of truth for the macOS/Apple-Silicon floor, restated at every
// download/purchase CTA on the page (#154) so a visitor learns it without
// scrolling to the mid-page "System requirements" section.
const REQUIREMENT_LINE = 'Apple Silicon · macOS 26+';
const REQUIREMENT_TOOLTIP = `Requires ${REQUIREMENT_LINE}`;

// ── Founding countdown, synced to the demo video drop (#377) ──────────────
// The 300-cap Founding run's urgency is pinned to the demo video release so peak
// scarcity lands in the launch-week share window. This DEMO_VIDEO_DROP constant is
// the single source of truth — update this one line when GTM locks the drop date.
// The countdown itself is now gated on a live checkout URL (#560) — see
// foundingUrgency below.
const DEMO_VIDEO_DROP = new Date('2026-07-24T12:00:00-05:00');
const dropLabel = DEMO_VIDEO_DROP.toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric', timeZone: 'America/Chicago',
});
const dropDeadlineIso = DEMO_VIDEO_DROP.toISOString();
const urgency = foundingUrgency({
  nowMs: Date.now(),
  deadlineMs: DEMO_VIDEO_DROP.getTime(),
  checkoutLive: isCheckoutLive(process.env),
});

type ProofCard =
  | { kind: 'image'; title: string; body: string; image: typeof liveCaptureScreenshot; alt: string }
  | { kind: 'preview'; title: string; body: string };

const proofCards: ProofCard[] = [
  {
    kind: 'image',
    title: 'Multitrack capture when you need it',
    body: 'Record 8 to 32 channels straight from your interface, stems saved per strip — the real FOH workflow behind the report card.',
    image: liveCaptureScreenshot,
    alt: 'Sound Buddy live capture interface showing armed audio channels',
  },
  {
    kind: 'preview',
    title: 'Browser Lite analysis',
    body: 'The same grading engine, running locally in a browser tab — a fast read on a stream feed or stereo file before you open the app.',
  },
  {
    kind: 'image',
    title: 'Virtual soundcheck, the follow-up',
    body: 'Once you know what broke, bring the stems back through the desk and rehearse the fix before next Sunday.',
    image: momentumShot,
    alt: 'Sound Buddy app chrome showing capture, live, soundcheck, and report card tabs',
  },
];

const steps: { n: string; title: string; body: string; link?: { href: string; label: string } }[] = [
  { n: '1', title: 'Bring in last Sunday', body: 'Use the stream recording you already have, a USB export from the console, or a quick laptop capture.', link: { href: '/record-your-service', label: 'How to record your service →' } },
  { n: '2', title: 'See what actually happened', body: 'Sound Buddy grades loudness, dynamics, spectral balance, and speech vs. music — fully on your Mac, instead of leaving you with "felt muddy."' },
  { n: '3', title: 'Rehearse the fix', body: 'Turn the report card into practical next moves, then use virtual soundcheck to replay the room as separate tracks before next Sunday.' },
];

const tiers = [
  {
    name: 'Founding Lifetime',
    price: '$199',
    cadence: 'one-time',
    blurb: 'Pay once, own Pro forever. A one-time purchase your church can expense — no recurring vendor approval, no annual budget re-justification.',
    cta: 'Become a Founding Member',
    ctaHref: FOUNDING_URL,
    ctaVariant: 'primary',
    founding: true,
    features: ['Everything in Pro, forever', 'One payment — no subscription', 'Lifetime license key (offline, never expires)', 'All future Pro features included', 'Limited founding run — 300 licenses'],
  },
  {
    name: 'Pro Monthly',
    price: '$9',
    cadence: '/ month',
    blurb: 'For the engineer who wants every channel, every week.',
    cta: 'Start your 14-day Pro trial',
    ctaHref: DOWNLOAD_URL,
    ctaVariant: 'primary',
    features: ['Record up to 32 channels', 'Per-strip stems + session manifest', 'AI analyst on your local Ollama', 'Channel groups, rigs & profiles', 'Priority email support'],
  },
  {
    name: 'Pro Annual',
    price: '$79',
    cadence: '/ year',
    blurb: 'Two months free. Built for the church budget cycle.',
    cta: 'Start your 14-day Pro trial',
    ctaHref: DOWNLOAD_URL,
    ctaVariant: 'ghost',
    features: ['Everything in Pro Monthly', 'Save ~$29 vs. monthly', 'Single PO / receipt for finance', 'All future Pro features included'],
  },
  {
    name: 'Free',
    price: '$0',
    cadence: 'forever',
    blurb: 'For the volunteer running Sunday once a week.',
    cta: 'Start free — grade your mix',
    ctaHref: DOWNLOAD_URL,
    ctaVariant: 'ghost',
    features: ['Record up to 8 channels', 'Full report card + letter grade', 'Spectral & dynamics analysis', 'Virtual soundcheck playback'],
  },
];
---

<Layout
  title="Sound Buddy — Get a clear answer from last Sunday's mix."
  description="Sound Buddy grades the recording you already have and names exactly what to fix before next Sunday — loudness, dynamics, spectral balance, and speech clarity. Try it free in your browser, or run the full workflow locally on your Mac."
>
  <!-- ── Header ─────────────────────────────────────────────────── -->
  <header class="site-header">
    <div class="container header-row">
      <a class="brand" href="/" aria-label="Sound Buddy home">
        <span class="brand-mark" aria-hidden="true">
          <BrandMark />
        </span>
        <span class="brand-name">Sound Buddy</span>
      </a>
      <nav class="header-nav" aria-label="Primary">
        <a href="#how">How it works</a>
        <a href={BROWSER_URL}>Browser Lite</a>
        <a href="#proof">App proof</a>
        <a href="#faq">FAQ</a>
        <a href="#pricing">Pricing</a>
      </nav>
      <a class="btn btn-primary" href={DOWNLOAD_URL} rel="noopener" title={REQUIREMENT_TOOLTIP}>Grade last Sunday's mix</a>
    </div>
  </header>

  <!-- ── Hero ───────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">For church FOH volunteers &amp; worship engineers</span>
        <h1>Get a clear answer from last Sunday's mix.</h1>
        <p class="hero-lede">
          Stop guessing what went wrong. Sound Buddy grades the recording you already have and
          names exactly what to fix before next Sunday — fully on your own machine.
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary btn-lg" href={DOWNLOAD_URL} rel="noopener">Grade last Sunday's mix</a>
          <a class="btn btn-ghost btn-lg" href={BROWSER_URL}>Try Browser Lite free</a>
        </div>
        <div class="hero-chips">
          <span class="hero-chip">Local-first</span>
          <span class="hero-chip">No cloud uploads</span>
          <span class="hero-chip">No account required</span>
        </div>
        <p class="hero-fine mono">{REQUIREMENT_LINE}</p>
      </div>
      <div class="hero-visual hero-collage">
        <figure class="hero-tile hero-tile-live card">
          <img
            src={liveCaptureScreenshot.src}
            alt="Sound Buddy live capture screen showing armed audio channels and analysis controls"
            loading="eager"
            decoding="async"
          />
          <figcaption><span class="mono">Live Capture</span></figcaption>
        </figure>
        <a class="hero-tile hero-tile-browser card" href={BROWSER_URL}>
          <div class="hero-tile-browser-inner">
            <BrowserLitePreview />
          </div>
          <span class="hero-tile-caption"><span class="mono">Browser Lite — runs in this tab</span></span>
        </a>
        <figure class="hero-tile hero-tile-report card">
          <img
            src={reportCardShot.src}
            alt="Sound Buddy report card screenshot showing a mix grade"
            loading="lazy"
            decoding="async"
          />
          <figcaption><span class="mono">Report Card</span></figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ── Trust bar ──────────────────────────────────────────────── -->
  <section class="trust tight">
    <div class="container trust-grid">
      <div class="trust-item">
        <span class="trust-icon" aria-hidden="true">🔒</span>
        <div>
          <strong>No cloud. No accounts. No cross-site tracking.</strong>
          <p>Analysis runs on-device. Your recordings stay on your Mac, full stop.</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon" aria-hidden="true">⌁</span>
        <div>
          <strong>Works with the AI you already have.</strong>
          <p>Bring Ollama, or paste an API key. Sound Buddy meets you where you are.</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon" aria-hidden="true">♩</span>
        <div>
          <strong>Built by live-sound engineers.</strong>
          <p>For the volunteer and the staff audio lead at the church FOH desk.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Real app proof ────────────────────────────────────────── -->
  <section id="proof" class="section proof-section">
    <div class="container">
      <span class="eyebrow">Real app proof</span>
      <h2 class="h2">This is a real workflow, not a single-card demo.</h2>
      <p class="lede">
        The report card is the front door. Behind it is multitrack capture, a browser-based quick
        check, and a rehearsal loop that turns the diagnosis into a fix.
      </p>
      <div class="proof-grid">
        {proofCards.map((c) => (
          <article class="proof-card card">
            {c.kind === 'preview' ? (
              <a class="proof-preview-link" href={BROWSER_URL} aria-label="Open Browser Lite">
                <BrowserLitePreview />
              </a>
            ) : (
              <img src={c.image.src} alt={c.alt} loading="lazy" />
            )}
            <div class="proof-copy">
              <h3>{c.title}</h3>
              <p>{c.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── How it works ───────────────────────────────────────────── -->
  <section id="how" class="section">
    <div class="container">
      <span class="eyebrow">How it works</span>
      <h2 class="h2">From service to fix in three steps.</h2>
      <div class="steps">
        {steps.map((s) => (
          <div class="step card">
            <span class="step-n mono">{s.n}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
            {s.link && <a class="step-link" href={s.link.href}>{s.link.label}</a>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Report card showcase ───────────────────────────────────── -->
  <section id="report-card" class="section rc-showcase">
    <div class="container rc-showcase-grid">
      <div class="rc-showcase-copy">
        <span class="eyebrow">The aha moment</span>
        <h2 class="h2">A letter grade for the whole service — and the levers to pull.</h2>
        <p class="lede">
          Every service gets a grade, a content timeline (speech, music, silence), and a metric
          table that points at what to change next week. Bass running hot? Speech buried?
          Sound Buddy names it, so you can fix it.
        </p>
        <p class="lede">
          This is the front door — proof the diagnosis is real — not the whole product. Capture,
          Browser Lite, and virtual soundcheck are the workflow behind it.
        </p>
        <ul class="rc-bullets">
          <li>Loudness, true peak &amp; dynamic range against real targets</li>
          <li>Spectral balance across seven bands</li>
          <li>Speech-intelligibility estimate for the spoken word</li>
          <li>Virtual soundcheck — replay the room as separate stems</li>
        </ul>
      </div>
      <div class="rc-showcase-visual">
        <ReportCard />
      </div>
    </div>
  </section>

  <!-- ── Browser Lite vs. desktop app ─────────────────────────────── -->
  <section id="browser-lite" class="section tight browser-compare">
    <div class="container">
      <span class="eyebrow">Browser Lite vs. desktop app</span>
      <h2 class="h2">A browser tool worth opening.</h2>
      <p class="lede">
        Browser Lite is the fastest way to taste the core promise — drop in a stereo file or tap a
        live input, get a quick grade right in the tab. The desktop app is where the deeper
        rehearsal workflow lives.
      </p>
      <div class="compare-grid">
        <div class="compare-card card">
          <span class="wa-icon" aria-hidden="true">🌐</span>
          <span class="eyebrow">Browser</span>
          <h3>Fast answer</h3>
          <ul class="rc-bullets wa-list">
            <li>Local-only stereo quick-grade, no install and no cloud step</li>
            <li>Live input mode for a stream feed or matrix send</li>
            <li>Copy notes straight into a team debrief</li>
          </ul>
          <a class="btn btn-primary" href={BROWSER_URL}>Open Browser Lite</a>
        </div>
        <div class="compare-card card">
          <span class="wa-icon" aria-hidden="true">🎚</span>
          <span class="eyebrow">Desktop</span>
          <h3>Deep rehearsal workflow</h3>
          <ul class="rc-bullets wa-list">
            <li>Record 8 to 32 channels straight from your interface</li>
            <li>Full report card, history, channel groups, and saved rigs</li>
            <li>Virtual soundcheck — replay the room, week after week</li>
          </ul>
          <a class="btn btn-ghost" href={DOWNLOAD_URL} rel="noopener">Get the Mac app</a>
          <p class="req-fine mono">{REQUIREMENT_LINE}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Pricing ────────────────────────────────────────────────── -->
  <section id="pricing" class="section pricing">
    <div class="container">
      <span class="eyebrow">Pricing</span>
      <h2 class="h2">Founding Lifetime — pay $199 once, own Pro forever.</h2>
      <p class="lede">First 300 churches only, through July. Prefer to pay as you go? $9/mo or $79/yr below — 14-day Pro trial on first launch, no card, no account.</p>
      {urgency.mode === 'countdown' && (
        <div class="founding-countdown" data-drop-deadline={dropDeadlineIso}>
          <span class="fc-pulse" aria-hidden="true"></span>
          <p class="fc-copy">
            Founding pricing locks with the demo video drop —
            <time datetime={dropDeadlineIso}>{dropLabel}</time>.
            <strong data-fc-remaining>{urgency.remainingLabel}</strong>{' '}
            to claim one of {FOUNDING_CAP}.
          </p>
        </div>
      )}
      {urgency.mode === 'cap' && (
        <div class="founding-cap">
          <p class="fc-copy">Limited to {FOUNDING_CAP} founding licenses — one-time $199, then Founding closes.</p>
        </div>
      )}
      <a class="guarantee" href={REFUND_PATH}>
        <span class="guarantee-icon" aria-hidden="true">✓</span>
        <span class="guarantee-copy">{GUARANTEE_BADGE}</span>
      </a>
      <div class="tiers">
        {tiers.map((t) => (
          <div class={`tier card ${t.founding ? 'founding' : ''}`}>
            {t.founding && <span class="tier-flag">Founding &middot; first 300 &middot; through July</span>}
            <h3>{t.name}</h3>
            <div class="tier-price"><span class="price">{t.price}</span><span class="cadence">{t.cadence}</span></div>
            <p class="tier-blurb">{t.blurb}</p>
            <a class={`btn ${t.ctaVariant === 'primary' ? 'btn-primary' : 'btn-ghost'}`} href={t.ctaHref} rel="noopener">{t.cta}</a>
            <p class="tier-req mono">{REQUIREMENT_LINE}</p>
            <ul class="tier-features">
              {t.features.map((f) => <li>{f}</li>)}
            </ul>
          </div>
        ))}
      </div>
      <p class="pricing-note">
        See our <a href={REFUND_PATH}>Refund Policy</a>, <a href="/terms">Terms</a> &amp; <a
          href="/privacy">Privacy Policy</a>. Pricing set with the church budget cycle in mind.
      </p>
    </div>
  </section>

  <!-- ── FAQ / objection handling ───────────────────────────────── -->
  <section id="faq" class="section faq">
    <div class="container">
      <span class="eyebrow">Questions</span>
      <h2 class="h2">The things churches ask before they install.</h2>
      <p class="lede">
        Short answers to what actually blocks the decision — privacy, the unsigned
        install, the AI, and what happens if it doesn't work out.
      </p>
      <div class="faq-list">
        {FAQ_ENTRIES.map((entry) => (
          <details class="faq-item card" id={`faq-${entry.id}`}>
            <summary>
              <h3>{entry.question}</h3>
              <span class="faq-chevron" aria-hidden="true">+</span>
            </summary>
            <div class="faq-answer">
              {entry.answer.map((p) => <p>{p}</p>)}
              {entry.link && <a class="faq-link" href={entry.link.href}>{entry.link.label}</a>}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Privacy callout ────────────────────────────────────────── -->
  <section class="section privacy">
    <div class="container privacy-card card">
      <span class="eyebrow">Privacy</span>
      <h2 class="h2">Your audio never leaves your machine.</h2>
      <p class="lede">
        No cloud uploads. No accounts. Nothing that tracks you across the web. Sound Buddy does
        its analysis on-device — that's the whole point. If you opt into AI, you pick the provider
        (Ollama locally, or your own API key). Nothing is sent anywhere by default. Browser Lite is
        local-only too — audio decoding and analysis happen in your browser tab, not on a server.
      </p>
      <div class="privacy-pills">
        <span class="pill good">No cloud</span>
        <span class="pill good">No accounts</span>
        <span class="pill good">No cross-site tracking</span>
        <span class="pill info">Optional local AI</span>
      </div>
      <p class="lede storage-line">
        <strong>Unlimited recordings. Stored on your machine.</strong> No caps on any tier — record
        and analyze as much as you want. It all stays on your own disk.
      </p>
    </div>
  </section>

  <!-- ── System requirements ────────────────────────────────────── -->
  <section class="section tight sysreq">
    <div class="container sysreq-grid">
      <div>
        <span class="eyebrow">System requirements</span>
        <h2 class="h2">Runs on the Mac you already own.</h2>
        <ul class="sysreq-list">
          <li><strong>Mac</strong> — Apple Silicon (M1 or newer)</li>
          <li><strong>macOS</strong> — 26 (Tahoe) or newer</li>
          <li><strong>Audio interface</strong> — any Core Audio device, up to 32 inputs</li>
          <li><strong>Disk</strong> — ~5 GB for the app + room for recordings</li>
        </ul>
      </div>
      <div class="sysreq-cta card">
        <h3>Ready to grade your next service?</h3>
        <p>Download Sound Buddy and get a report card from this Sunday's recording in under five minutes.</p>
        <a class="btn btn-primary btn-lg" href={DOWNLOAD_URL} rel="noopener">Grade this Sunday's mix</a>
        <a class="btn btn-ghost btn-lg" href="#how">See how it works</a>
        <details class="install-walkthrough" id="install-walkthrough">
          <summary>First launch on macOS — the unsigned-install flow</summary>
          <ol>
            <li>Download the <code>.zip</code>, unzip, and drag <strong>Sound Buddy.app</strong> to <strong>/Applications</strong>.</li>
            <li>First launch is blocked by Gatekeeper ("Apple could not verify Sound Buddy").</li>
            <li>Open <strong>System Settings → Privacy &amp; Security</strong>, scroll to the <strong>Security</strong> section, and click <strong>Open Anyway</strong> next to the Sound Buddy message.</li>
            <li>Confirm <strong>Open Anyway</strong> and authenticate.</li>
          </ol>
          <p class="install-walkthrough-alt">
            Power-user alternative: <code>xattr -dr com.apple.quarantine "/Applications/Sound Buddy.app"</code>
          </p>
          <img
            class="install-walkthrough-gif"
            src="/install-walkthrough.gif"
            alt="Step-by-step screen recording of opening System Settings, navigating to Privacy & Security, and clicking Open Anyway to launch the unsigned Sound Buddy build on macOS 26"
            loading="lazy"
          />
        </details>
      </div>
    </div>
  </section>

  <!-- ── Footer ─────────────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="container footer-row">
      <div class="footer-brand">
        <span class="brand-mark" aria-hidden="true">
          <BrandMark size={20} />
        </span>
        <span>Sound Buddy</span>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        <a href={DOWNLOAD_URL} rel="noopener" title={REQUIREMENT_TOOLTIP}>Download</a>
        <a href={BROWSER_URL}>Browser Lite</a>
        <a href="/record-your-service">Recording guide</a>
        <a href={REPO_URL} rel="noopener">GitHub</a>
        <a href="#faq">FAQ</a>
        <a href="#pricing">Pricing</a>
        <a href={REFUND_PATH}>Refunds</a>
        <a href="/terms">Terms</a>
        <a href="/privacy">Privacy</a>
        <a href={`mailto:support@soundbuddy.online`}>Support</a>
      </nav>
      <p class="footer-meta mono">© {new Date().getFullYear()} <a href="https://onpardev.com" rel="noopener">On PAR Dev</a> · Built for worship teams</p>
    </div>
  </footer>
</Layout>

<script>
  import { FOUNDING_CAP, remainingLabel } from '../lib/founding-urgency';
  const MINUTE_MS = 60_000;
  const el = document.querySelector<HTMLElement>('[data-drop-deadline]');
  const out = el?.querySelector<HTMLElement>('[data-fc-remaining]');
  const raw = el?.getAttribute('data-drop-deadline');
  if (el && out && raw) {
    const deadline = new Date(raw).getTime();
    const tick = () => {
      const diff = deadline - Date.now();
      if (diff <= 0) {
        // Deadline passed in an open tab: drop the timer entirely rather than
        // freeze on "0m left" or assert a claim we can't back (#560).
        el.textContent = `Limited to ${FOUNDING_CAP} founding licenses — one-time $199, then Founding closes.`;
        return;
      }
      out.textContent = remainingLabel(diff);
    };
    tick();
    setInterval(tick, MINUTE_MS);
  }
</script>

<style>
  /* ── Header ── */
  .site-header { position: sticky; top: 0; z-index: 10; background: color-mix(in srgb, var(--bg-app) 88%, transparent); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border-subtle); }
  .header-row { display: flex; align-items: center; gap: 20px; height: 64px; }
  .brand { display: inline-flex; align-items: center; gap: 9px; font: var(--fw-semibold) var(--fs-body-lg)/1 var(--font-sans); color: var(--text-primary); }
  .brand-mark { display: inline-flex; }
  .header-nav { display: flex; gap: 22px; margin-left: auto; font: var(--fw-medium) var(--fs-body-sm)/1 var(--font-sans); color: var(--text-secondary); }
  .header-nav a { padding: 6px 0; border-bottom: 1px solid transparent; transition: color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out); }
  .header-nav a:hover { color: var(--text-primary); border-bottom-color: var(--gold-500); }
  .site-header .btn { height: 36px; padding: 0 16px; }

  /* ── Hero ── */
  .hero { padding: 72px 0 88px; background:
      radial-gradient(900px 480px at 78% 0%, var(--gold-tint-soft), transparent 70%),
      radial-gradient(700px 420px at 12% 12%, var(--azure-tint), transparent 72%); }
  .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
  .hero-copy h1 { font: var(--fw-bold) var(--fs-display)/var(--lh-tight) var(--font-sans); letter-spacing: var(--tracking-tight); margin: 16px 0 18px; color: var(--text-primary); }
  .hero-lede { font: var(--fw-regular) var(--fs-h3)/var(--lh-relaxed) var(--font-sans); color: var(--text-secondary); max-width: 52ch; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .hero-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 22px; }
